# --- Model (Claude via Vertex AI, ADK native `Claude` class) ---
# The agent uses ADK's native google.adk.models.anthropic_llm.Claude, which talks
# to Vertex directly. Auth is GCP ADC via GOOGLE_APPLICATION_CREDENTIALS above
# (no Anthropic API key needed). Requires `pip install "anthropic[vertex]"`.
EDCA_MODEL=claude-opus-4-8
GOOGLE_CLOUD_PROJECT=tecovas-prod-edw
# Claude on Vertex is region-restricted — us-east5 serves Opus; us-central1 generally does NOT.
GOOGLE_CLOUD_LOCATION=us-east5
